# ─────────────────────────────────────────────────────────────────
#  GiveHope — Environment Variables Template
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:5173
# Used to build links inside emails (verification, password reset)
FRONTEND_URL=http://localhost:5173

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=givehope_db
DB_USER=root
DB_PASSWORD=yourpassword

# JWT — secrets must be at least 32 characters long
JWT_ACCESS_SECRET=change_me_to_a_32_char_min_random_string
JWT_REFRESH_SECRET=change_me_to_another_32_char_min_string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# SendGrid
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@givehope.com
SENDGRID_FROM_NAME=GiveHope

# Razorpay (primary payment gateway — INR)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxx

# Stripe (secondary — international)
STRIPE_SECRET_KEY=STRIPE_SECRET_KEY=sk_live_YOUR_STRIPE_KEY_HERE
STRIPE_WEBHOOK_SECRET=STRIPE_SECRET_KEY=sk_live_YOUR_STRIPE_KEY_HERE

# Cloudinary (optional — image uploads)
CLOUDINARY_CLOUD_NAME=xxxxxx
CLOUDINARY_API_KEY=xxxxxxxxxxxxxx
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxx
