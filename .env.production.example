# ── Server ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# Comma-separated list of allowed frontend origins (no trailing slash)
ALLOWED_ORIGINS=https://yourdomain.com

# Used for email verification / password-reset links
FRONTEND_URL=https://yourdomain.com

# ── Database ─────────────────────────────────────────────────────────────────────
# Docker Compose: use the service name "db"
# AWS RDS / PlanetScale / Aiven: use the remote endpoint
DB_HOST=db
DB_PORT=3306
DB_NAME=givehope_db
DB_USER=givehope_user
DB_PASSWORD=a_very_strong_db_password

# ── JWT ───────────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=<paste 64-char random string here>
JWT_REFRESH_SECRET=<paste a different 64-char random string here>
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── SendGrid ──────────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Must be a Sender Verified in SendGrid dashboard → Settings → Sender Authentication
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=GiveHope

# ── Razorpay (live keys) ──────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
# Set in Razorpay dashboard → Settings → Webhooks → Webhook Secret
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxx

# ── Stripe (live keys) ────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=YOUR_STRIPE_LIVE_SECRET_KEY_HERE
# Set in Stripe dashboard → Developers → Webhooks → Signing Secret
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET_HERE

# ── Cloudinary (optional — for image uploads) ────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Docker Compose only ───────────────────────────────────────────────────────────
# Root password for the MySQL container (not used by the app — only by the healthcheck)
MYSQL_ROOT_PASSWORD=a_different_strong_root_password
